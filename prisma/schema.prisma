generator client {
  provider = "prisma-client-js"
  previewFeatures = ["multiSchema"] // 👈 เพิ่มบรรทัดนี้
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["music_dave"] // 👈 เช็คตัวสะกด (-) หรือ (_) ให้ตรงกับใน Supabase
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model album {
  album_id  Int     @id
  title     String  @db.VarChar(160)
  artist_id Int
  artist    artist  @relation(fields: [artist_id], references: [artist_id], onDelete: NoAction, onUpdate: NoAction)
  track     track[]

  @@index([artist_id])
  @@schema("music_dave") // 👈 เพิ่มบรรทัดนี้
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model artist {
  artist_id Int     @id
  name      String? @db.VarChar(120)
  album     album[]
  @@schema("music_dave") // 👈 เพิ่มบรรทัดนี้
}

model customer {
  customer_id    Int       @id @default(autoincrement())
  first_name     String    @db.VarChar(40)
  last_name      String    @db.VarChar(20)
  company        String?   @db.VarChar(80)
  address        String?   @db.VarChar(70)
  postal_code    String?   @db.VarChar(10)
  phone          String?   @db.VarChar(24)
  email          String    @unique @db.VarChar(60)
  password       String?
  @@schema("music_dave") // 👈 เพิ่มบรรทัดนี้
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model genre {
  genre_id Int     @id
  name     String? @db.VarChar(120)
  track    track[]
  @@schema("music_dave") // 👈 เพิ่มบรรทัดนี้
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model track {
  track_id       Int              @id
  name           String           @db.VarChar(200)
  album_id       Int?
  media_type_id  Int
  genre_id       Int?
  composer       String?          @db.VarChar(220)
  milliseconds   Int
  bytes          Int?
  unit_price     Decimal          @db.Decimal(10, 2)
  album          album?           @relation(fields: [album_id], references: [album_id], onDelete: NoAction, onUpdate: NoAction)
  genre          genre?           @relation(fields: [genre_id], references: [genre_id], onDelete: NoAction, onUpdate: NoAction)

  @@index([album_id])
  @@index([genre_id])
  @@index([media_type_id])
  @@schema("music_dave") // 👈 เพิ่มบรรทัดนี้
}
